# Copy file này thành .env và điền giá trị thật. KHÔNG commit .env lên git.

# Supabase Storage - lấy từ Settings → API của project Supabase
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...   # service_role key, KHÔNG dùng anon
SUPABASE_BUCKET=audios               # tên bucket bạn đã tạo

# Database (optional) - bỏ trống để dùng SQLite local
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
